# Server Configuration
PORT=8000
LOG_LEVEL=INFO
DEBUG=false

# Cloud LLM API Keys (Comma separated for multiple keys)
# Get your keys at:
# Gemini: https://aistudio.google.com/app/apikey
# Groq: https://console.groq.com/keys
# Cerebras: https://cloud.cerebras.ai/
GEMINI_KEYS=your_gemini_key_1,your_gemini_key_2
GROQ_KEYS=your_groq_key
CEREBRAS_KEYS=your_cerebras_key

# Default Thresholds
MAX_TOKENS_FAST_MODEL=8192

# Model Tier Overrides (Optional - Comma separated substrings)
FREE_MODELS=flash,lite,llama-3.1-8b,ollama
PREMIUM_MODELS=pro,ultra,70b,gpt-4o

# Default Models for 'auto' routing
DEFAULT_FREE_MODEL=gemini-flash-latest
DEFAULT_PREMIUM_MODEL=gemini-pro-latest

# Scraping Configuration
DEFAULT_SCRAPE_MODE=standard  # standard, simple, network_only
ENABLE_CONTEXT_COMPRESSION=false

# Session Configuration
MAX_SESSIONS=50

# --- Automatic Routing Logic (Heuristics) ---
# When model is set to "auto", the gateway selects models based on these rules:
# 1. Multimodal Check: If images are present, Gemini (Vision) is prioritized.
# 2. Token-based Routing:
#    - < 1,500 tokens: Groq (Ultra-fast, Llama 3.3 70B)
#    - < 5,000 tokens: Cerebras (High-speed, Llama 3.1 70B)
#    - > 5,000 tokens: Gemini (High context window)
# 3. Tier-Awareness: For Gemini, Pro is used ONLY if a premium key is available.
#    Otherwise, it falls back to Flash (Free but high context).
# 4. Web Search Fallback: If 'has_search' is True but no premium keys exist, 
#    the gateway uses its internal Playwright scraper to get real-time info.

# Local Agent Engines (Optional)
OLLAMA_BASE_URL=http://localhost:11434/v1
OPENCODE_BASE_URL=http://localhost:4096/v1
OPENCLAW_BASE_URL=http://localhost:18789/v1
